# Alpaca API (required)
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
ALPACA_LIVE=false

# Telegram notifications (optional)
# 1. Message @BotFather → /newbot → copy token
# 2. Message your bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates → find chat_id
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Feature flags
ASYNC_MODE=false
