# ============================================================
# Velox V12 — Environment Configuration Template
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
# ============================================================

# ============================================================
# REQUIRED — Alpaca API (get keys at https://app.alpaca.markets)
# ============================================================
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
ALPACA_LIVE=false

# ============================================================
# REQUIRED — Docker Infrastructure
# ============================================================
POSTGRES_USER=velox
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=velox
DATABASE_URL=postgresql://velox:change_me_strong_password@postgres:5432/velox
GRAFANA_ADMIN_PASSWORD=change_me_strong_password

# ============================================================
# V12: Dashboard Auth (optional — disabled if DASHBOARD_SECRET_KEY is empty)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
# DASHBOARD_SECRET_KEY=
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD_HASH=
# DASHBOARD_TOKEN_EXPIRY_HOURS=24

# ============================================================
# Logging & Web
# ============================================================
STRUCTURED_LOGGING=true
WEB_DASHBOARD_ENABLED=true
WEB_DASHBOARD_PORT=8080

# ============================================================
# V12: Telegram Notifications (optional)
# 1. Message @BotFather on Telegram -> /newbot -> copy token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id
# ============================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# V12: Free API Keys (optional — improves signal quality)
# ============================================================
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html (free)
# FRED_API_KEY=

# ============================================================
# Trading Behavior
# ============================================================
ALLOW_SHORT=false
DYNAMIC_ALLOCATION=true
PDT_PROTECTION_ENABLED=true

# ============================================================
# V12 Feature Flags — Active by default
# ============================================================
PEAD_PRE_EARNINGS_ENABLED=true
INTRADAY_REGIME_ENABLED=true
ML_ENSEMBLE_ENABLED=true
NLP_SENTIMENT_ENABLED=true
OPTIONS_SKEW_ENABLED=true
DARK_POOL_ENABLED=true
LEAD_LAG_ENABLED=true
EDGAR_MONITOR_ENABLED=true
BAYESIAN_KELLY_ENABLED=true
BLACK_LITTERMAN_ENABLED=true
MACRO_SURPRISE_ENABLED=true

# ============================================================
# V12 Feature Flags — Disabled by default (experimental)
# ============================================================
TFT_ENABLED=false
ALPHA_AGENTS_ENABLED=false
ORDER_BOOK_SIGNAL_ENABLED=false
ADAPTIVE_SCAN_ENABLED=false
LLM_SCORING_ENABLED=false
RL_EXECUTION_ENABLED=false

# ============================================================
# Optional API Keys (uncomment and fill to enable)
# ============================================================
# ANTHROPIC_API_KEY=        # For LLM signal scoring ($0.10/day cap)
# FMP_API_KEY=              # For PEAD earnings data (falls back to yfinance)
# OPENAI_API_KEY=           # For FinGPT alternative backend
