# Alpaca API (required)
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
ALPACA_LIVE=false

# Telegram notifications (optional)
# 1. Message @BotFather → /newbot → copy token
# 2. Message your bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates → find chat_id
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# V10: Dashboard authentication (optional — disabled if not set)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# DASHBOARD_SECRET_KEY=
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD_HASH=

# V10: Database (optional — defaults to SQLite bot.db)
# For PostgreSQL: postgresql://user:pass@localhost:5432/velox
# DATABASE_URL=

# V10: Structured logging (set to true for JSON output)
# STRUCTURED_LOGGING=false

# V10: Docker Compose credentials (required for docker compose up)
POSTGRES_USER=velox
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=velox
GRAFANA_ADMIN_PASSWORD=change_me_strong_password
